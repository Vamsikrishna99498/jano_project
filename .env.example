# ==================================================
# Core Settings (required for all use cases)
# ==================================================
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_DB_PASSWORD@localhost:5432/resume_ai
VECTOR_INDEX_PATH=./data/faiss_resume.index
VECTOR_META_PATH=./data/faiss_resume_meta.json
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Parser behavior defaults (safe local-first)
LLM_MODE=none
LLM_MODEL=gpt-4o-mini
FORCE_LLM_ONLY=false

# ==================================================
# Provider Credentials (fill only if you use that provider)
# ==================================================

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PROJECT=
OPENAI_ORGANIZATION=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01

# ==================================================
# Use Cases (copy values into active vars above)
# ==================================================

# Use case 1: Fully local / deterministic parser only (no external LLM)
# LLM_MODE=none
# FORCE_LLM_ONLY=false

# Use case 2: Heuristic parser first, OpenAI fallback only on low confidence
# LLM_MODE=openai
# LLM_MODEL=gpt-4o-mini
# FORCE_LLM_ONLY=false
# OPENAI_API_KEY=sk-...

# Use case 3: Heuristic parser first, Anthropic fallback only on low confidence
# LLM_MODE=anthropic
# LLM_MODEL=claude-3-5-sonnet-latest
# FORCE_LLM_ONLY=false
# ANTHROPIC_API_KEY=...

# Use case 4: Force LLM-only parsing with OpenAI
# LLM_MODE=openai
# LLM_MODEL=gpt-4o-mini
# FORCE_LLM_ONLY=true
# OPENAI_API_KEY=sk-...

# Use case 5: Force LLM-only parsing with Anthropic
# LLM_MODE=anthropic
# LLM_MODEL=claude-3-5-sonnet-latest
# FORCE_LLM_ONLY=true
# ANTHROPIC_API_KEY=...
